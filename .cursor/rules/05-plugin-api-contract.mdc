# Plugin API Contract

> **Khi thay đổi `CMSPlugin` interface hoặc thêm hooks mới → cập nhật file này.**
> Source of truth: `packages/types/src/plugin.ts`

## Interface CMSPlugin (hiện tại)

```typescript
// packages/types/src/plugin.ts
interface PluginLifecycle {
  onInstall?:   (db: unknown) => void | Promise<void>
  onUninstall?: (db: unknown) => void | Promise<void>
  onEnable?:    (cms: ViseedCMS) => void | Promise<void>
  onDisable?:   (cms: ViseedCMS) => void | Promise<void>
}

interface PluginAdminMenuItem {
  id: string
  label: string
  icon: string
  path: string                       // admin route path, e.g. '/blog/posts'
  requiredPermissions?: PermissionKey[] // built-in OR plugin-declared keys
  siteScoped?: boolean
  order?: number                     // lower = higher in sidebar
  componentExport?: string           // export name in admin bundle
}

// Plugin-declared permission. Reuse built-in keys freely (no need to redeclare);
// only declare entries here for plugin-specific permissions. Declared entries
// surface in the admin Roles view and become valid grant targets.
interface PermissionDef {
  key: PermissionKey   // 'site.content.read' (built-in) | 'pages.publish' (custom)
  label: string
  description?: string
  group?: string       // grouping bucket for the Roles UI
}

interface PluginAdminConfig {
  menuItems: PluginAdminMenuItem[]
  bundlePath?: string                // absolute path to compiled admin ESM bundle
}

interface WidgetTypeDef {
  id: string              // unique, pattern: '{pluginName}/{typeName}', e.g. 'blog/latest-posts'
  label: string
  icon?: string
  description?: string
  pluginName: string      // must match CMSPlugin.name
  configComponent: string // export name in plugin admin bundle (Vue form)
  previewComponent?: string // optional preview in TipTap NodeView
  publicComponent: string // export name in plugin public bundle (Vue renderer)
  defaultConfig?: Record<string, unknown>
}

interface PluginPublicConfig {
  bundlePath?: string  // absolute path to compiled public ESM bundle (widget renderers)
}

// Dashboard widgets render INSIDE the admin SPA (not the public site).
// Component is resolved from the plugin admin bundle — no public bundle needed.
type DashboardWidgetSize = '1x1' | '2x1' | '3x1' | '4x1' | '2x2' | '3x2' | '4x2'

interface DashboardWidgetDef {
  id: string                     // unique, pattern: '{pluginName}/{name}', e.g. 'blog/recent-posts'
  label: string
  icon?: string
  description?: string
  pluginName: string             // must match CMSPlugin.name
  component: string              // export name in plugin admin bundle (Vue component)
  supportedSizes: DashboardWidgetSize[]
  defaultSize: DashboardWidgetSize
}

interface CMSPlugin {
  name: string      // required — unique identifier, dùng kebab-case
  version: string   // required — semver (vd: "1.0.0")
  schema?: Record<string, unknown>    // Drizzle table objects từ plugin
  hooks?: Partial<CMSPluginHooks>     // lifecycle hooks
  routes?: (app: Hono, helpers: CMSRouteContextHelpers) => void
  lifecycle?: PluginLifecycle         // install/uninstall/enable/disable callbacks
  admin?: PluginAdminConfig           // admin UI menu items + ESM bundle path
  widgets?: WidgetTypeDef[]           // widget types this plugin contributes
  dashboardWidgets?: DashboardWidgetDef[] // admin dashboard widgets (rendered in admin SPA)
  public?: PluginPublicConfig         // public-facing ESM bundle (Vue widget renderers)
  storageProviders?: StorageProviderDef[] // media storage providers (e.g. S3, R2)
  permissions?: PermissionDef[]       // custom permissions this plugin declares
  // helpers.resolveRequestContext(c): chuẩn hóa site + actor + permissions
  // helpers.hasPermission(c, permission): kiểm tra quyền thống nhất với core
  // helpers.createSubApp(basePath): core tạo + mount sub-router cho plugin
  //   (plugin KHÔNG tự `new Hono()`, chỉ `import type { Hono }`)
}

// PluginRouter — secure-by-default: mọi method protected BẮT BUỘC khai báo
// permission (key string built-in/custom HOẶC PermissionDef từ definePermission).
// Truyền PermissionDef → metadata tự vào Roles view, khỏi khai plugin.permissions.
// Route public phải opt-out tường minh qua `public.*`.
type PermissionArg = PermissionKey | PermissionDef
interface PluginRouter {
  get:    (path: string, permission: PermissionArg, handler: Handler) => void
  post:   (path: string, permission: PermissionArg, handler: Handler) => void
  put:    (path: string, permission: PermissionArg, handler: Handler) => void
  delete: (path: string, permission: PermissionArg, handler: Handler) => void
  public: { get; post; put; delete }   // (path, handler) — KHÔNG auth, dùng hạn chế
}

// definePermission — tạo custom permission có metadata (IDE bắt buộc key+label),
// giữ literal key. Dùng cho plugin.permissions HOẶC truyền thẳng vào route.
function definePermission<const K extends string>(
  def: PermissionDef & { key: K },
): PermissionDef & { key: K }

interface CMSRouteContextHelpers {
  resolveRequestContext: (c: Context) => RequestContext
  hasPermission: (c: Context, permission: Permission) => boolean
  createSubApp: (basePath: string) => PluginRouter  // permission-aware; core owns Hono
}

interface CMSPluginHooks {
  'cms:init':            (cms: ViseedCMS) => void | Promise<void>
  'cms:ready':           (app: Hono)    => void | Promise<void>
  'admin:register':      (registry: ComponentRegistry) => void
  'theme:mount':         (theme: CMSTheme) => void | Promise<void>
  'theme:beforeRender':  (layoutKey: string, data: Record<string, unknown>) => Record<string, unknown> | Promise<Record<string, unknown>>
  'theme:activate':      (theme: CMSTheme, previousTheme?: CMSTheme) => void | Promise<void>
  'plugin:enabled':      (pluginName: string) => void | Promise<void>
  'plugin:disabled':     (pluginName: string) => void | Promise<void>
}
```

## Lifecycle Hooks — Thứ tự thực thi

```
1. createCMS(config)            → ViseedCMS constructor, đăng ký tất cả plugins
2. cms.launch()
   ├─ registerThemes()          → xây dựng themeRegistry + themeRuntimes
   ├─ createDatabase()          → merge schemas từ core + plugins + companionPlugin schemas
   ├─ hooks.run('cms:init')     → mỗi plugin nhận ViseedCMS instance (setup DB, services)
   ├─ PluginRouteRegistry       → đăng ký sub-routers cho plugins + companionPlugins
   ├─ syncPluginActiveStateFromDb() → activate plugins có enabled=1 trong DB
   ├─ app.use('*', registry.middleware()) → single middleware dispatch tới active plugins
   ├─ resolveActiveTheme()      → nếu có theme registry:
   │   ├─ mountThemeRoutes()    → đăng ký routes cho mỗi layout (hỗ trợ routePattern override)
   │   ├─ activate companionPlugin → nếu active theme có companionPlugin
   │   └─ hooks.run('theme:mount') → plugins nhận CMSTheme instance
   ├─ setupAdminApi()           → đăng ký /api/admin routes (bao gồm plugin enable/disable)
   ├─ setupAdminServing()       → serve admin SPA
   └─ hooks.run('cms:ready')    → app đã có routes, chuẩn bị nhận request
3. admin:register               → được gọi khi Admin UI khởi tạo ComponentRegistry
4. theme:beforeRender           → mỗi request tới theme route, trước khi Eta render
5. theme:activate               → khi admin gọi POST /api/admin/themes/:name/activate;
                                   Cũng toggle companionPlugin (deactivate old, activate new).
6. plugin:enabled               → sau khi plugin được activate (bao gồm companionPlugin)
7. plugin:disabled              → sau khi plugin bị deactivate
```

## Quy tắc viết Plugin

### Schema

```typescript
// ✅ Đúng — export Drizzle table objects
import { sqliteTable, text, integer } from 'drizzle-orm/sqlite-core'

export const posts = sqliteTable('blog_posts', {
  id: integer('id').primaryKey({ autoIncrement: true }),
  title: text('title').notNull(),
})

// Plugin export schema object
export const schema = { posts }
```

- Table name **phải có prefix** của plugin để tránh conflict (`blog_posts`, không phải `posts`)
- Schema phải là plain Drizzle table objects — KHÔNG custom SQL string (đó là Community plugin)
- `mergeSchemas()` sẽ throw nếu có key trùng nhau

### Routes

```typescript
// ✅ Đúng — dùng helpers.createSubApp, KHÔNG import hono runtime
import type { Hono } from 'hono'
import type { CMSRouteContextHelpers } from '@viseed/types'
import { PERMISSIONS } from '@viseed/types' // hằng built-in (autocomplete + refactor-safe)

export function setupBlogRoutes(_app: Hono, helpers: CMSRouteContextHelpers): void {
  const blog = helpers.createSubApp('/api/blog') // permission-aware sub-router
  // method protected: bắt buộc permission key; core lo auth + RBAC guard
  blog.get('/posts', PERMISSIONS.siteContentRead, async (c) => {
    return c.json({ posts: [] }) // lấy db qua cms:init hook
  })
  blog.post('/posts', PERMISSIONS.siteContentWrite, async (c) => {
    return c.json({ ok: true })
  })
  // route public (vd login) phải opt-out tường minh:
  blog.public.get('/feed.xml', async (c) => c.text('<rss/>'))
}
```

- **Secure-by-default**: mỗi method protected BẮT BUỘC truyền `permission` (TS-enforced).
  Core resolve session + site, set request context, và chặn 401 (chưa đăng nhập)
  / 403 (thiếu quyền) TRƯỚC khi handler chạy. KHÔNG tự gọi `hasPermission` trong handler nữa.
- Dùng hằng `PERMISSIONS.*` (vd `PERMISSIONS.siteContentRead`) cho built-in permission —
  có autocomplete + refactor-safe. Gõ chuỗi cũng được (LiteralUnion vẫn gợi ý). Built-in
  là single source of truth ở `BUILTIN_PERMISSION_DEFS`; thêm mới chỉ sửa 1 chỗ.
- **Custom permission**: tạo bằng `definePermission` (IDE bắt buộc `key` + `label`,
  gợi ý `group`/`description`), rồi truyền THẲNG def vào route — metadata tự vào Roles
  view, KHỎI khai lại trong `plugin.permissions`:

```typescript
import { definePermission } from '@viseed/types'

const PAGES_PUBLISH = definePermission({
  key: 'pages.publish',
  label: 'Publish pages',
  group: 'Pages',
})

export function setupPagesRoutes(_app: Hono, helpers: CMSRouteContextHelpers): void {
  const api = helpers.createSubApp('/api/pages')
  api.put('/:id/publish', PAGES_PUBLISH, async (c) => c.json({ ok: true }))
  // (hoặc dùng PAGES_PUBLISH.key nếu chỉ cần chuỗi)
}
```

- Phân biệt read/write: GET → `*.read`, POST/PUT/DELETE → `*.write`/`*.manage`.
- Route công khai (không auth) phải dùng `blog.public.*` — dùng hạn chế.
- Tái dùng built-in permission key thoải mái; chỉ khai `CMSPlugin.permissions`
  cho permission riêng của plugin. Permission khai báo + tham chiếu (menuItems/routes)
  đều tự xuất hiện trong Roles view qua `PermissionRegistry`.
- Routes prefix bằng tên plugin: `/api/blog`, `/api/auth`, `/api/menus`
- KHÔNG `new Hono()` và KHÔNG `import { Hono } from 'hono'` (runtime). Chỉ
  `import type { Hono }`; tạo sub-app qua `helpers.createSubApp(basePath)`.
  Core mount sub-app SAU khi plugin định nghĩa xong routes (Hono snapshot routes
  tại thời điểm `.route()`), nên không cần tự mount.
- `hono` là devDependency (type-only); KHÔNG đặt ở dependencies.
- KHÔNG tự tạo DB connection — nhận qua `cms:init` hook

### Hooks

```typescript
// ✅ Đúng — lấy db trong cms:init
let db: DatabaseInstance

export const hooks: CMSPlugin['hooks'] = {
  'cms:init': async (cms) => {
    db = cms.getDatabase()
  },
}
```

### Plugin Factory Pattern

```typescript
// ✅ Chuẩn — export factory function
import type { CMSPlugin } from '@viseed/types'

export function createBlogPlugin(options?: BlogPluginOptions): CMSPlugin {
  return {
    name: 'plugin-blog',
    version: '1.0.0',
    schema,
    hooks,
    routes,
  }
}

// Dùng:
createCMS({
  plugins: [createBlogPlugin({ postsPerPage: 10 })],
})
```

## Two-Type Plugin Architecture

| | Official Plugins | Community Plugins |
|---|---|---|
| Phân phối | npm package | CDN/S3 ESM bundle |
| Cài đặt | `bun add` + restart | dynamic import, không restart |
| Schema | Drizzle type-safe objects | raw SQL string (`schema_sql`) |
| Dependencies | full npm deps | self-bundled, không external deps |
| Ví dụ | `@viseed/plugin-auth` | third-party từ registry |

### Admin UI Registration

Plugins can register menu items and Vue admin views via the `admin` field:

```typescript
export function blogPlugin(): CMSPlugin {
  return {
    name: 'blog',
    version: '0.1.0',
    admin: {
      menuItems: [
        { id: 'blog-posts', label: 'Posts', icon: '✎', path: '/blog/posts', order: 20, componentExport: 'PostsView' },
      ],
      bundlePath: resolve(__dirname, '../dist/admin/index.js'),
    },
    // ...
  }
}
```

- Plugin self-builds admin Vue components as an ESM bundle (`build:admin` script using Vite library mode)
- `vue` and `vue-router` are externalized — resolved at runtime via Import Map in admin's `index.html`
- Core serves the bundle at `GET /api/admin/plugins/:name/ui.js`
- Admin SPA fetches plugin manifest from `GET /api/admin/plugin-manifest`, then `import()`s bundles dynamically
- **Admin has zero dependency on any plugin package** — all plugin UI loads at runtime

### Plugin Hot-swap (Runtime Enable/Disable)

Plugins can be enabled/disabled at runtime without restarting the server:

```
POST /api/admin/plugins/:name/install   → lifecycle.onInstall(db) + DB record
POST /api/admin/plugins/:name/uninstall → lifecycle.onUninstall(db) + delete DB record
POST /api/admin/plugins/:name/enable    → lifecycle.onEnable(cms) + activate routes + DB enabled=1
POST /api/admin/plugins/:name/disable   → lifecycle.onDisable(cms) + deactivate routes + DB enabled=0
GET  /api/admin/plugins                 → list installed plugins with enabled status
```

`PluginRouteRegistry` wraps each plugin in its own sub-router. Only active plugins receive requests.

### Companion Plugins (Theme-bound)

A theme can declare `companionPlugin?: CMSPlugin` — a full plugin (schema + routes + hooks + lifecycle) that auto-activates when the theme activates and auto-deactivates when the theme deactivates.

Companion plugin schemas are always migrated at startup. Only routes are toggled.

## Widget System API

Plugin registers widget types via `widgets?: WidgetTypeDef[]` on `CMSPlugin`. Core auto-builds `WidgetTypeRegistry` from active plugins and provides:

```
GET  /api/admin/widget-types          → list all active widget types
GET  /api/admin/widgets               → list site-scoped widget instances
GET  /api/admin/widgets/:id           → get single instance
POST /api/admin/widgets               → create instance (requires site.widgets.manage)
PUT  /api/admin/widgets/:id           → update config/name
DELETE /api/admin/widgets/:id         → delete instance
GET  /api/widgets/:id                 → public fetch (no auth, cached), for CSR hydration
GET  /api/public/plugins/:name/widget.js → serve plugin public bundle
GET  /api/public/widget-runtime.js   → serve widget hydration runtime (built via Bun.build)
GET  /api/public/vendor-vue.js       → serve shared Vue vendor bundle
```

Permissions: `site.widgets.read` (read/list), `site.widgets.manage` (create/update/delete).

Plugin public bundle pattern:
- Source: `src/public/index.ts` with named Vue component exports
- Build: `build-public.ts` (Vite lib, `external: ['vue']`, outDir: `dist/public`)
- Plugin factory: `public: { bundlePath: resolve(__dirname, '../dist/public/index.js') }`

### Preview component — config thật

`WidgetEmbedView.vue` (TipTap NodeView trong admin) fetches `/api/admin/widgets/:id` và truyền `config` thật vào `previewComponent`:

```html
<component :is="previewComponent" :config="widgetInfo?.config ?? {}" />
```

Preview giờ hiển thị đúng nội dung widget đã lưu (không còn truyền `{}` rỗng).

Convention: admin barrel nên re-export public renderer với tên `previewComponent` để dùng làm preview trong NodeView (xem `plugin-common-widgets/src/admin/index.ts`).

## Storage Provider System API

Plugin đóng góp media storage backend (S3, R2, …) qua `storageProviders?: StorageProviderDef[]`. Core gom thành `StorageProviderRegistry` (rebuild cùng `WidgetTypeRegistry` khi enable/disable plugin) và dùng để render form admin, validate, mã hoá secret, dựng adapter. `local` là provider built-in của core, KHÔNG nằm trong registry.

```typescript
// packages/types/src/cms.ts
interface StorageAdapter {
  save(filename: string, data: ArrayBuffer, siteId: string, contentType?: string): Promise<string>
  delete(path: string): Promise<void>
  getUrl(path: string, siteId: string): string
  isLocal(): boolean
}

interface StorageProviderField {
  name: string                 // key lưu vào media_storage_config.config
  label: string
  type: 'text' | 'password'
  required?: boolean
  secret?: boolean             // mã hoá at-rest (secret-cipher) + mask '***' trong API
  placeholder?: string
  hint?: string
}

interface StorageProviderDef {
  type: string                 // unique, lưu ở media_storage_config.type (vd 's3')
  label: string                // 'Amazon S3'
  fields: StorageProviderField[]
  createAdapter: (config: Record<string, unknown>) => StorageAdapter // nhận config ĐÃ giải mã
}
```

Quy tắc:
- Storage-only plugin KHÔNG cần schema/routes/admin → deps chỉ `@viseed/types` + SDK (vd `@aws-sdk/client-s3`).
- `fields[]` là cơ chế "extra field": plugin tự khai báo tham số tuỳ ý, core lưu generic vào `config` jsonb — không cần đổi core khi thêm param mới.
- Secret được core mã hoá trước khi lưu; plugin chỉ nhận plaintext trong `createAdapter`.

Admin API:
```
GET  /api/admin/media/storage-config            → { type, config (secret đã mask) }
GET  /api/admin/media/storage-config/providers  → { providers: [{ type, label, fields }] }
PUT  /api/admin/media/storage-config            → lưu + hot-swap adapter
POST /api/admin/media/storage-config/test       → thử kết nối (save+delete file tạm)
```
Permissions: đọc `platform.sites.read`, ghi/test `platform.sites.manage`. `MediaStorageSettings.vue` render form động từ providers + `local` built-in.

Cách dùng: `createCMS({ plugins: [s3Plugin()] })` rồi cấu hình ở Admin > Media > Settings. Không truyền tham số storage trong code.

## Dashboard Widget System API

Khác với content widget (render ở public site), **dashboard widget render trong admin SPA**. Plugin khai báo qua `dashboardWidgets?: DashboardWidgetDef[]`; component nằm trong **admin bundle** (`src/admin/index.ts`) — không cần public bundle, không cần build script mới. Core gom thành `DashboardWidgetRegistry` (rebuild cùng lúc với `WidgetTypeRegistry` khi enable/disable plugin) và cung cấp:

```
GET    /api/admin/dashboard-widget-types   → list dashboard widget types khả dụng (+ pluginEnabled)
GET    /api/admin/dashboard-widgets         → list placements của site (sort theo position)
POST   /api/admin/dashboard-widgets         → thêm placement (validate type + size ∈ supportedSizes)
PUT    /api/admin/dashboard-widgets/reorder → nhận { ids: string[] } đã sắp xếp → cập nhật position
PUT    /api/admin/dashboard-widgets/:id     → đổi size (validate ∈ supportedSizes)
DELETE /api/admin/dashboard-widgets/:id     → xóa placement
```

Permissions: đọc dùng `site.content.read`, sửa layout dùng `site.widgets.manage` (không thêm permission mới).

- Placements lưu ở bảng `dashboard_widgets` (`@viseed/schema`), **per-site** (`siteId`), gồm `type`, `size`, `position`.
- Admin Dashboard (`apps/admin/src/views/DashboardView.vue`) render CSS grid 4 cột; size dạng `colspan x rowspan` (colspan cap = 4). Component resolve qua `usePluginComponent().resolveComponent(pluginName, component)` từ admin bundle đã load sẵn.
- Tương tác v1: add/remove + dropdown size + move up/down (reorder). Chưa có drag-drop, chưa có per-instance config.

