# Copy this file to .env then edit the values for drizzle-kit

PORT=3000
DATABASE_URL=postgresql://username:password@host:25060/viseed?sslmode=verify-full&sslrootcert=./ca-certificate.crt

# Required when using S3/R2 remote storage — used to encrypt secretAccessKey at rest.
# Generate with: openssl rand -base64 32
# Must not have a default; keep this secret and never commit the real value.
VISEED_ENCRYPTION_KEY=

# Docker Hub — dùng cho scripts/deploy.ts (bun run docker:push)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKER_HUB_IMAGE=
