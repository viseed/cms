{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Starter Dev",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/apps/starter/src/index.ts",
      "cwd": "${workspaceFolder}/apps/starter",
      "watchMode": true
    },
    {
      "name": "Debug Playground Dev",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/apps/playground/src/index.ts",
      "cwd": "${workspaceFolder}/apps/playground",
      "watchMode": true
    },
    {
      "name": "Debug Admin Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev",
      "cwd": "${workspaceFolder}/apps/admin"
    },
    {
      "name": "Debug Docs Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev",
      "cwd": "${workspaceFolder}/apps/docs"
    }
  ]
}
