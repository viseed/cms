{
  "name": "viseed-cms",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "plugins/*",
    "themes/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=!@viseed/docs",
    "build:plugins": "turbo run build --filter=\"./plugins/*\"",
    "clean": "turbo run clean && rimraf .turbo node_modules/.cache",
    "dev:docs": "turbo run dev --filter=@viseed/docs",
    "dev": "turbo run dev --filter=@viseed/schema --filter=@viseed/types --filter=@viseed/validator --filter=@viseed/core --filter=@viseed/admin --filter=@viseed/starter --filter=@viseed/theme-insurance",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@changesets/cli": "^2.29.0",
    "bunup": "^0.16.31",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.12",
    "typescript": "^5.8.0",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  },
  "dependencies": {
    "@types/bun": "^1.3.11"
  },
  "overrides": {
    "@tiptap/core": "3.22.3",
    "@tiptap/vue-3": "3.22.3",
    "@tiptap/starter-kit": "3.22.3",
    "@tiptap/pm": "3.22.3"
  }
}
