{
  "name": "hana-cms",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "plugins/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:plugins": "turbo run build --filter=\"./plugins/*\"",
    "dev:core": "turbo run dev --filter=@hana/core",
    "dev:admin": "turbo run dev --filter=@hana/admin",
    "dev:starter": "turbo run dev --filter=@hana/starter",
    "dev:docs": "turbo run dev --filter=@hana/docs",
    "dev": "turbo run dev --filter=@hana/core --filter=@hana/admin --filter=@hana/starter --filter=@hana/docs",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@changesets/cli": "^2.29.0",
    "bunup": "^0.16.31",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@types/bun": "^1.3.11"
  }
}