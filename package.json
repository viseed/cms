{
  "name": "hana-cms",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "plugins/*",
    "themes/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:plugins": "turbo run build --filter=\"./plugins/*\"",
    "clean": "turbo run clean && rimraf .turbo node_modules/.cache",
    "dev:docs": "turbo run dev --filter=@hana/docs",
    "dev": "turbo run dev --filter=@hana/schema --filter=@hana/types --filter=@hana/validator --filter=@hana/core --filter=@hana/admin --filter=@hana/starter --filter=@hana/theme-blog",
    "dev:insurance": "turbo run dev --filter=@hana/schema --filter=@hana/types --filter=@hana/validator --filter=@hana/core --filter=@hana/admin --filter=@hana/starter --filter=@hana/theme-insurance",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@changesets/cli": "^2.29.0",
    "bunup": "^0.16.31",
    "drizzle-kit": "^0.31.10",
    "rimraf": "^6.1.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  },
  "dependencies": {
    "@types/bun": "^1.3.11"
  }
}
