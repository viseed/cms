{
  "name": "@viseed/core",
  "version": "0.5.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "bun": "./src/build.ts",
      "import": "./dist/build.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bunup",
    "clean": "rimraf dist",
    "dev": "bunup --no-dts --watch",
    "dev:post": "tsc --watch -p tsconfig.build.json",
    "test": "bun test",
    "test:unit": "bun test",
    "test:integration": "bun test integration"
  },
  "dependencies": {
    "@tiptap/core": "3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/html": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@viseed/schema": "workspace:*",
    "@viseed/types": "workspace:*",
    "@viseed/validator": "workspace:*",
    "drizzle-orm": "0.44.7",
    "eta": "^4.5.1",
    "hono": "^4.7.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@viseed/config": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.2.0",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
