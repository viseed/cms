{
  "name": "@hana/core",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunup",
    "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
    "dev": "bunup --watch",
    "dev:post": "rimraf tsconfig.build.tsbuildinfo && tsc --watch -p tsconfig.build.json",
    "test": "bun test"
  },
  "dependencies": {
    "@hana/schema": "workspace:*",
    "@hana/types": "workspace:*",
    "@hana/validator": "workspace:*",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/html": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "drizzle-orm": "0.44.7",
    "hono": "^4.7.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@hana/config": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6"
  }
}
