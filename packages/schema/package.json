{
  "name": "@hanano/schema",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunup",
    "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
    "dev": "bunup --no-dts --watch",
    "dev:post": "rimraf tsconfig.build.tsbuildinfo && tsc --watch -p tsconfig.build.json",
    "test": "bun test"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@hanano/config": "workspace:*",
    "@hanano/types": "workspace:*"
  }
}
