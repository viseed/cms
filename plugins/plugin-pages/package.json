{
  "name": "@viseed/plugin-pages",
  "version": "2.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "bun": "./src/schema.ts",
      "import": "./dist/schema.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bunup --no-dts && tsc -p tsconfig.build.json && bun run build-admin.ts",
    "build:admin": "bun run build-admin.ts",
    "clean": "rimraf dist",
    "test": "bun test"
  },
  "dependencies": {
    "@viseed/types": "0.3.0"
  },
  "peerDependencies": {
    "@viseed/core": "0.3.0",
    "@viseed/validator": "0.3.0",
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@viseed/config": "0.1.0",
    "@viseed/core": "0.3.0",
    "@viseed/validator": "0.3.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vue": "^3.5.0",
    "vite": "^6.2.0"
  }
}
