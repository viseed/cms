<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Not Found — <%= it.settings.siteTitle || 'Hana Blog' %></title>
  <link rel="stylesheet" href="/theme/static/css/style.css">
  <% if (it.settings['general.brandColor']) { %>
    <style>:root { --brand: <%= it.settings['general.brandColor'] %>; }</style>
  <% } %>
</head>
<body>
  <%~ include('partials/header', it) %>

  <main class="container">
    <div class="not-found">
      <h1>404</h1>
      <p>The page you are looking for could not be found.</p>
      <a href="/" class="btn">Back to Home</a>
    </div>
  </main>

  <%~ include('partials/footer', it) %>
</body>
</html>
