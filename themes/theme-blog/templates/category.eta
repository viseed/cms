<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= it.data.category ? it.data.category.name + ' — ' : '' %><%= it.settings.siteTitle || 'Hana Blog' %></title>
  <link rel="stylesheet" href="/theme/static/css/style.css">
  <% if (it.settings['general.brandColor']) { %>
    <style>:root { --brand: <%= it.settings['general.brandColor'] %>; }</style>
  <% } %>
</head>
<body>
  <%~ include('partials/header', it) %>

  <main class="container">
    <% if (it.data.category) { %>
      <section class="category-archive">
        <h1><%= it.data.category.name %></h1>
        <% if (it.data.category.description) { %>
          <p class="category-desc"><%= it.data.category.description %></p>
        <% } %>

        <div class="post-list">
          <% if (it.data.posts && it.data.posts.length) { %>
            <% for (const post of it.data.posts) { %>
              <article class="post-card">
                <h3><a href="/post/<%= post.slug %>"><%= post.title %></a></h3>
                <% if (post.excerpt) { %>
                  <p class="post-excerpt"><%= post.excerpt %></p>
                <% } %>
                <time class="post-date"><%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : '' %></time>
              </article>
            <% } %>
          <% } else { %>
            <p class="empty-state">No posts in this category yet.</p>
          <% } %>
        </div>
      </section>
    <% } else { %>
      <div class="not-found">
        <h1>Category not found</h1>
        <p>The category you are looking for does not exist.</p>
        <a href="/" class="btn">Back to Home</a>
      </div>
    <% } %>
  </main>

  <%~ include('partials/footer', it) %>
</body>
</html>
