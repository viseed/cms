<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <p class="footer-title"><%= it.settings.siteTitle || 'Viseed Blog' %></p>
        <p class="footer-desc"><%= it.settings.siteDescription || '' %></p>
      </div>
      <% if (it.settings['footer.footerLinks'] && it.settings['footer.footerLinks'].length) { %>
        <div class="footer-links">
          <% for (const link of it.settings['footer.footerLinks']) { %>
            <a href="<%= link.url %>"><%= link.label %></a>
          <% } %>
        </div>
      <% } %>
      <% if (it.settings['footer.socialLinks'] && it.settings['footer.socialLinks'].length) { %>
        <div class="footer-social">
          <% for (const link of it.settings['footer.socialLinks']) { %>
            <a href="<%= link.url %>" target="_blank" rel="noopener"><%= link.label %></a>
          <% } %>
        </div>
      <% } %>
    </div>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> <%= it.settings.siteTitle || 'Viseed Blog' %>. Powered by Viseed CMS.</p>
  </div>
</footer>
