<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <p class="footer-title">{{ settings.siteTitle or 'Hana Blog' }}</p>
        <p class="footer-desc">{{ settings.siteDescription or '' }}</p>
      </div>
      {% if settings['footer.footerLinks'] and settings['footer.footerLinks'].length %}
        <div class="footer-links">
          {% for link in settings['footer.footerLinks'] %}
            <a href="{{ link.url }}">{{ link.label }}</a>
          {% endfor %}
        </div>
      {% endif %}
      {% if settings['footer.socialLinks'] and settings['footer.socialLinks'].length %}
        <div class="footer-social">
          {% for link in settings['footer.socialLinks'] %}
            <a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <p class="footer-copy">&copy; {{ currentYear }} {{ settings.siteTitle or 'Hana Blog' }}. Powered by Hana CMS.</p>
  </div>
</footer>
