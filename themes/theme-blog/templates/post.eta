<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%~ it.helpers.seoHead(it) %>
  <link rel="stylesheet" href="/theme/static/css/style.css">
  <% if (it.settings['general.brandColor']) { %>
    <style>:root { --brand: <%= it.settings['general.brandColor'] %>; }</style>
  <% } %>
</head>
<body>
  <%~ include('partials/header', it) %>

  <main class="container">
    <% if (it.data.post) { %>
      <article class="article">
        <header class="article-header">
          <h1><%= it.data.post.title %></h1>
          <div class="article-meta">
            <time><%= it.data.post.publishedAt ? new Date(it.data.post.publishedAt).toLocaleDateString() : '' %></time>
          </div>
        </header>
        <div class="article-body">
          <%~ it.data.post.bodyHtml || '' %>
        </div>
      </article>
    <% } else { %>
      <div class="not-found">
        <h1>Post not found</h1>
        <p>The article you are looking for does not exist.</p>
        <a href="/" class="btn">Back to Home</a>
      </div>
    <% } %>
  </main>

  <%~ include('partials/footer', it) %>
</body>
</html>
