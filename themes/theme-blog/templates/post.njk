<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if data.post %}{{ data.post.title }} — {% endif %}{{ settings.siteTitle or 'Hana Blog' }}</title>
  <link rel="stylesheet" href="/theme/static/css/style.css">
  {% if settings['general.brandColor'] %}
    <style>:root { --brand: {{ settings['general.brandColor'] }}; }</style>
  {% endif %}
</head>
<body>
  {% include "partials/header.njk" %}

  <main class="container">
    {% if data.post %}
      <article class="article">
        <header class="article-header">
          <h1>{{ data.post.title }}</h1>
          <div class="article-meta">
            <time>{{ data.post.publishedAt | dateFormat }}</time>
          </div>
        </header>
        <div class="article-body">
          {{ data.post.bodyHtml | safe }}
        </div>
      </article>
    {% else %}
      <div class="not-found">
        <h1>Post not found</h1>
        <p>The article you are looking for does not exist.</p>
        <a href="/" class="btn">Back to Home</a>
      </div>
    {% endif %}
  </main>

  {% include "partials/footer.njk" %}
</body>
</html>
