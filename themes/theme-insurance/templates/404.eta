<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%~ it.helpers.seoHead(it) %>
  <% for (const url of (it.assets?.css ?? [])) { %><link rel="stylesheet" href="<%= url %>"><% } %>
  <% if (it.settings['general.faviconUrl']) { %><link rel="icon" href="<%= it.settings['general.faviconUrl'] %>"><% } %>
</head>
<body>
  <%~ include('partials/header', it) %>

  <main class="error-page">
    <div class="container error-page-content">
      <div class="error-code">404</div>
      <h1 class="error-title">Không tìm thấy trang</h1>
      <p class="error-description">
        Xin lỗi, trang bạn đang tìm kiếm không thể tìm thấy.<br>
        Trang có thể đã được chuyển hoặc xóa.
      </p>
      <div class="error-actions">
        <a href="/" class="btn btn-primary">Về trang chủ</a>
        <% if (it.settings['header.contactPhone']) { %>
          <a href="tel:<%= it.settings['header.contactPhone'].replace(/\s/g, '') %>" class="btn btn-outline">
            Liên hệ chúng tôi
          </a>
        <% } %>
      </div>
    </div>
  </main>

  <%~ include('partials/footer', it) %>
  <%~ include('partials/preview-inject', it) %>
</body>
</html>
