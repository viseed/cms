<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= it.data.category ? it.data.category.name + ' — ' : '' %><%= it.settings['general.siteName'] || 'Insurance' %>
  </title>
  <% for (const url of (it.assets?.css ?? [])) { %><link rel="stylesheet" href="<%= url %>"><% } %>
</head>
<body>
  <%~ include('partials/header', it) %>

  <div class="page-hero page-hero--small">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span><%= it.data.category ? it.data.category.name : 'Category' %></span>
      </nav>
    </div>
  </div>

  <main class="container page-content">
    <% if (it.data.category) { %>
      <div class="category-header">
        <h1 class="page-title"><%= it.data.category.name %></h1>
        <% if (it.data.category.description) { %>
          <p class="page-description"><%= it.data.category.description %></p>
        <% } %>
      </div>

      <% if (it.data.posts && it.data.posts.length) { %>
        <div class="posts-grid">
          <% for (const post of it.data.posts) { %>
            <article class="post-card">
              <div class="post-card-body">
                <span class="post-label">Insurance</span>
                <h2 class="post-card-title">
                  <a href="/post/<%= post.slug %>"><%= post.title %></a>
                </h2>
                <% if (post.excerpt) { %>
                  <p class="post-card-excerpt"><%= post.excerpt %></p>
                <% } %>
                <div class="post-card-footer">
                  <time class="post-date">
                    <%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('vi-VN') : '' %>
                  </time>
                  <a href="/post/<%= post.slug %>" class="post-read-more">Read more →</a>
                </div>
              </div>
            </article>
          <% } %>
        </div>
      <% } else { %>
        <div class="empty-state-page">
          <p>No posts in this category yet.</p>
          <a href="/" class="btn-primary-link">Back to Home</a>
        </div>
      <% } %>
    <% } else { %>
      <div class="not-found-page">
        <h1>Category not found</h1>
        <p>The category you are looking for does not exist.</p>
        <a href="/" class="btn-primary-link">Back to Home</a>
      </div>
    <% } %>
  </main>

  <%~ include('partials/footer', it) %>
  <%~ include('partials/preview-inject', it) %>
</body>
</html>
