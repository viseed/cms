<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {% if data.post %}{{ data.post.title }} — {% endif %}{{ settings['general.siteName'] or 'Insurance' }}
  </title>
  <link rel="stylesheet" href="/theme/static/css/style.css">
</head>
<body>
  {% include "partials/header.njk" %}

  <div class="page-hero page-hero--small">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        {% if data.post and data.post.categoryId %}
          <a href="/category">Category</a>
          <span>›</span>
        {% endif %}
        <span>{{ data.post.title if data.post else 'Post' }}</span>
      </nav>
    </div>
  </div>

  <main class="container page-content">
    {% if data.post %}
      <div class="post-layout">
        <article class="post-article">
          <header class="article-header">
            <h1 class="article-title">{{ data.post.title }}</h1>
            <div class="article-meta">
              <time class="article-date">{{ data.post.publishedAt | dateFormatLong }}</time>
            </div>
            {% if data.post.excerpt %}
              <p class="article-lead">{{ data.post.excerpt }}</p>
            {% endif %}
          </header>

          <div class="article-body">
            {{ data.post.bodyHtml | safe }}
          </div>

          <div class="article-footer">
            <a href="javascript:history.back()" class="btn-back">← Back</a>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="post-sidebar">
          <!-- Related products / recent posts -->
          {% if data.posts and data.posts.length %}
            <div class="sidebar-card">
              <h3 class="sidebar-card-title">Related Articles</h3>
              <ul class="sidebar-post-list">
                {% for related in data.posts | excludeById(data.post.id) | take(5) %}
                  <li>
                    <a href="/post/{{ related.slug }}">{{ related.title }}</a>
                    <time>{{ related.publishedAt | dateFormat('vi-VN') }}</time>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <!-- Contact Card -->
          <div class="sidebar-card sidebar-contact-card">
            <h3 class="sidebar-card-title">Need help?</h3>
            <p class="sidebar-contact-text">Our team is ready to assist you</p>
            {% if settings['header.contactPhone'] %}
              <a href="tel:{{ settings['header.contactPhone'] | stripSpaces }}" class="sidebar-phone">
                📞 {{ settings['header.contactPhone'] }}
              </a>
            {% endif %}
            {% if settings['header.contactEmail'] %}
              <a href="mailto:{{ settings['header.contactEmail'] }}" class="sidebar-email">
                ✉ {{ settings['header.contactEmail'] }}
              </a>
            {% endif %}
          </div>
        </aside>
      </div>
    {% else %}
      <div class="not-found-page">
        <h1>Article not found</h1>
        <p>The article you are looking for does not exist.</p>
        <a href="/" class="btn-primary-link">Back to Home</a>
      </div>
    {% endif %}
  </main>

  {% include "partials/footer.njk" %}
</body>
</html>
