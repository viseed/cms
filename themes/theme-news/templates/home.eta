<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= it.settings.siteTitle || 'Hana News' %></title>
  <link rel="stylesheet" href="/theme/static/css/style.css">
  <% if (it.settings.brandColor) { %>
    <style>:root { --brand: <%= it.settings.brandColor %>; }</style>
  <% } %>
</head>
<body>
  <%~ include('partials/header', it) %>

  <main class="container">
    <% if (it.settings.showHero !== false) { %>
      <section class="hero">
        <h1><%= it.settings['general.siteTitle'] || 'Hana News' %></h1>
        <p><%= it.settings['general.siteDescription'] || 'A modern news site powered by Hana CMS' %></p>
      </section>
    <% } %>

    <div class="layout-grid">
      <section class="post-list">
        <h2>Latest Posts</h2>
        <% if (it.data.posts && it.data.posts.length) { %>
          <% for (const post of it.data.posts) { %>
            <article class="post-card">
              <h3><a href="/post/<%= post.slug %>"><%= post.title %></a></h3>
              <% if (post.excerpt) { %>
                <p class="post-excerpt"><%= post.excerpt %></p>
              <% } %>
              <time class="post-date"><%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : '' %></time>
            </article>
          <% } %>
        <% } else { %>
          <p class="empty-state">No posts published yet.</p>
        <% } %>
      </section>

      <% if (it.settings.showSidebar !== false) { %>
        <aside class="sidebar">
          <div class="sidebar-section">
            <h3>Categories</h3>
            <% if (it.data.categories && it.data.categories.length) { %>
              <ul class="category-list">
                <% for (const cat of it.data.categories) { %>
                  <li><a href="/category/<%= cat.slug %>"><%= cat.name %></a></li>
                <% } %>
              </ul>
            <% } else { %>
              <p class="empty-state">No categories yet.</p>
            <% } %>
          </div>
        </aside>
      <% } %>
    </div>
  </main>

  <%~ include('partials/footer', it) %>
</body>
</html>
