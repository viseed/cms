{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "12",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@viseed/core#build": {
      "dependsOn": ["@viseed/admin#build", "^build"],
      "outputs": ["dist/**"]
    },
    "build:admin": {
      "dependsOn": ["build"],
      "outputs": ["dist/admin/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "publish": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
